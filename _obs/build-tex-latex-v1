#!/usr/bin/env python3
"""
Assemble a LaTeX document from an outline file.

Reads an outline file whose tables reference segment files, and assembles a
single .tex document suitable for arXiv submission, with:

  - amsart document class with theorem-like environments for each claim type
  - Section structure preserved from outline
  - Segment content converted from markdown to LaTeX
  - Academic numbering via LaTeX's own counter system
  - Cross-references via \\label{}/\\ref{}
  - Working notes stripped; missing segments warned on stderr

Usage:
    bin/build-tex 01-act-core/OUTLINE.md                  # → stdout
    bin/build-tex 01-act-core/OUTLINE.md -o act-core.tex  # → file
"""

import argparse
import re
import sys
import warnings
from pathlib import Path


# ── Reused from bin/build ───────────────────────────────────────────────


def parse_table_row(line):
    """Parse '| a | b | c |' into ['a', 'b', 'c']. Returns None if not a table row."""
    stripped = line.strip()
    if not stripped.startswith('|') or not stripped.endswith('|'):
        return None
    cells = stripped.split('|')
    return [c.strip() for c in cells[1:-1]]


def is_separator_row(cells):
    return all(re.match(r'^[-:]+$', c) for c in cells if c)


def extract_slug_and_path(cell):
    m = re.search(r'\[#([\w-]+)\]\(([^)]+\.md)\)', cell)
    if m:
        return m.group(1), m.group(2)
    return None, None


def strip_frontmatter(text):
    lines = text.split('\n')
    if not lines or lines[0].strip() != '---':
        return text
    for i in range(1, len(lines)):
        if lines[i].strip() == '---':
            return '\n'.join(lines[i + 1:]).lstrip('\n')
    return text


def strip_working_notes(text):
    matches = list(re.finditer(r'^## Working Notes\b', text, re.MULTILINE))
    if not matches:
        return text
    return text[:matches[-1].start()].rstrip('\n') + '\n'


def resolve_segment(outline_dir, rel_path, slug):
    candidate = outline_dir / rel_path
    if candidate.exists():
        return candidate
    candidate = outline_dir / 'src' / f'{slug}.md'
    if candidate.exists():
        return candidate
    return None


def collect_slugs(lines):
    slugs = set()
    for line in lines:
        cells = parse_table_row(line)
        if cells:
            for cell in cells:
                s, _ = extract_slug_and_path(cell)
                if s:
                    slugs.add(s)
    return slugs


# ── Markdown → LaTeX conversion ────────────────────────────────────────


def tex_escape(text):
    """Escape characters special to LaTeX, but NOT inside math mode.

    Note: # is NOT escaped here — cross-ref rewriting handles #slug patterns,
    and stray # in prose is rare enough to handle manually. _ is escaped since
    underscores in prose (variable_name) need protection but math-mode underscores
    are handled by the math-region splitter.
    """
    text = text.replace('&', r'\&')
    text = text.replace('%', r'\%')
    # Don't escape # — it's used for cross-refs and rarely appears in prose
    text = text.replace('_', r'\_')
    # Don't escape { } — they appear in LaTeX commands we've already generated
    text = text.replace('~', r'\textasciitilde{}')
    text = text.replace('^', r'\textasciicircum{}')
    return text


def fix_math_escapes(math):
    """Convert GitHub-compatible math escapes to standard LaTeX."""
    math = math.replace(r'\gt', '>')
    math = math.replace(r'\lt', '<')
    math = math.replace(r'\ast', '*')
    # Fix \Vert and \vert immediately followed by a letter (no space/brace)
    # e.g. \Vertw → \Vert w, \Vertt → \Vert t
    math = re.sub(r'\\Vert([a-zA-Z])', r'\\Vert \1', math)
    math = re.sub(r'\\vert([a-zA-Z])', r'\\vert \1', math)
    return math


def protect_math_and_convert(line, converter):
    """Split line into math/non-math regions, apply converter only to non-math."""
    parts = []
    i = 0
    n = len(line)

    while i < n:
        # Inline code (backticks) — convert to \texttt
        if line[i] == '`':
            ticks = 0
            while i + ticks < n and line[i + ticks] == '`':
                ticks += 1
            closer = '`' * ticks
            end = line.find(closer, i + ticks)
            if end != -1:
                code_content = line[i + ticks:end]
                parts.append(r'\texttt{' + tex_escape(code_content) + '}')
                i = end + ticks
            else:
                parts.append(converter(line[i:]))
                i = n
            continue

        # Display math $$...$$ (inline on one line)
        if line[i] == '$' and i + 1 < n and line[i + 1] == '$':
            end = line.find('$$', i + 2)
            if end != -1:
                math = line[i:end + 2]
                math = fix_math_escapes(math)
                parts.append(math)
                i = end + 2
            else:
                parts.append(line[i:])
                i = n
            continue

        # Inline math $...$
        if line[i] == '$':
            end = line.find('$', i + 1)
            if end != -1:
                math = line[i:end + 1]
                math = fix_math_escapes(math)
                parts.append(math)
                i = end + 1
            else:
                parts.append(converter(line[i:]))
                i += 1
            continue

        # Regular text — find next special char
        j = i
        while j < n and line[j] not in ('$', '`'):
            j += 1
        parts.append(converter(line[i:j]))
        i = j

    return ''.join(parts)


def convert_inline_formatting(text):
    """Convert markdown bold/italic and links to LaTeX, handling only non-math text."""
    # Markdown links [text](url) → \href{url}{text} or just text for local refs
    def _convert_link(m):
        label, url = m.group(1), m.group(2)
        if url.endswith('.md') or url.startswith('#') or url.startswith('../'):
            return label  # local ref — just keep the label text
        return f'\\href{{{url}}}{{{label}}}'
    text = re.sub(r'\[([^\]]+)\]\(([^)]+)\)', _convert_link, text)
    # Bold+italic ***text*** or ___text___
    text = re.sub(r'\*\*\*(.+?)\*\*\*', r'\\textbf{\\textit{\1}}', text)
    # Bold **text**
    text = re.sub(r'\*\*(.+?)\*\*', r'\\textbf{\1}', text)
    # Italic *text* but not equation-level tags like *[Definition ...]*
    text = re.sub(r'(?<!\*)\*(?!\[)(.+?)(?<!\])\*(?!\*)', r'\\textit{\1}', text)
    return text


def convert_prose(text):
    """Convert a piece of non-math text: apply formatting first, then escape remaining."""
    # Links and formatting BEFORE escaping, since they use markdown syntax chars
    text = convert_inline_formatting(text)
    # Strip markdown footnote references [^1], [^note], etc.
    text = re.sub(r'\[\^[^\]]+\]', '', text)
    # Escape remaining special chars
    text = text.replace('&', r'\&')
    text = text.replace('%', r'\%')
    # Escape # but don't double-escape \#
    text = re.sub(r'(?<!\\)#', r'\\#', text)
    # Escape bare underscores not inside LaTeX commands
    text = re.sub(r'(?<!\\)_', r'\_', text)
    # Convert cross-ref markers to \cref
    text = re.sub(r'CREF:([\w-]+):CREF', r'\\S\\,\\ref{\1}', text)
    return text


def convert_line(line):
    """Convert a single line from markdown to LaTeX (inline elements only)."""
    result = protect_math_and_convert(line, convert_prose)
    # Catch any CREF markers that survived (e.g., in math regions)
    result = re.sub(r'CREF:([\w-]+):CREF', r'\\S\\,\\ref{\1}', result)
    return result


def md_table_to_latex(table_lines):
    """Convert a markdown table (list of raw lines) to a LaTeX tabular."""
    rows = []
    for line in table_lines:
        cells = parse_table_row(line)
        if cells is None:
            continue
        if is_separator_row(cells):
            continue
        rows.append(cells)

    if not rows:
        return ''

    ncols = max(len(r) for r in rows)
    col_spec = 'l' * ncols

    out = []
    out.append(r'\begin{adjustbox}{max width=\textwidth}')
    out.append(r'\small')
    out.append(r'\begin{tabular}{' + col_spec + '}')
    out.append(r'\toprule')

    for idx, row in enumerate(rows):
        cells = [convert_line(c) for c in row]
        while len(cells) < ncols:
            cells.append('')
        out.append(' & '.join(cells) + r' \\')
        if idx == 0:
            out.append(r'\midrule')

    out.append(r'\bottomrule')
    out.append(r'\end{tabular}')
    out.append(r'\end{adjustbox}')
    return '\n'.join(out)


def convert_display_math(content):
    """Convert display math block content to LaTeX display math."""
    content = content.strip()
    if content.startswith('$$'):
        content = content[2:]
    if content.endswith('$$'):
        content = content[:-2]
    content = content.strip()

    content = fix_math_escapes(content)

    # If it already has an align-like environment, just wrap in equation
    if r'\begin{aligned}' in content:
        return '\\begin{equation}\n' + content + '\n\\end{equation}'

    # Check if multi-line (multiple \\ separated expressions)
    if r'\\' in content and '\n' in content:
        return '\\begin{equation}\n\\begin{aligned}\n' + content + '\n\\end{aligned}\n\\end{equation}'

    return '\\[\n' + content + '\n\\]'


def convert_blockquote(lines):
    """Convert blockquote lines (starting with >) to LaTeX."""
    content = '\n'.join(re.sub(r'^>\s?', '', l) for l in lines)
    return '\\begin{quote}\n' + convert_line(content) + '\n\\end{quote}'


# ── Segment → LaTeX ────────────────────────────────────────────────────

# Map from segment type to LaTeX environment name
TYPE_TO_ENV = {
    'postulate':       'postulate',
    'definition':      'definition',
    'scope':           'scope',
    'formulation':     'formulation',
    'derived':         'proposition',
    'result':          'theorem',
    'corollary':       'corollary',
    'hypothesis':      'hypothesis',
    'normative':       'normative',
    'empirical':       'empirical',
    'observation':     'observation',
    'discussion':      'discussion',
    'measurement':     'measurement',
    'proposed-schema': 'schema',
    'derivation':      'derivation',
    'worked-example':  'example',
    'detail':          'detail',
    'sketch':          'sketch',
    'aside':           'aside',
}


def segment_to_latex(text, slug, seg_type, known_slugs):
    """Convert a full segment's markdown content to LaTeX.

    Returns a string of LaTeX content (not wrapped in an environment yet —
    the caller handles that based on the segment type).
    """
    text = strip_frontmatter(text)
    text = strip_working_notes(text)

    # Rewrite cross-references in raw markdown BEFORE LaTeX conversion
    text = rewrite_crossrefs_md(text, known_slugs)

    lines = text.split('\n')
    out = []

    # State
    in_display_math = False
    display_math_buf = []
    in_list = False
    list_type = None  # 'itemize' or 'enumerate'
    in_table = False
    table_buf = []
    in_blockquote = False
    blockquote_buf = []
    skip_until_next_heading = False
    current_heading_level = 0

    # Extract title from first heading
    title = slug
    for line in lines:
        hm = re.match(r'^#{1,6}\s+(.*)', line)
        if hm:
            raw_title = hm.group(1).strip()
            # Strip type prefix like "Result: " or "Definition: "
            cm = re.match(r'^(?:Postulate|Definition|Result|Derived|Hypothesis|Formulation|Scope|Discussion|Observation|Empirical|Normative|Corollary|Sketch|Detail|Derivation|Worked Example|Measurement|Proposed Schema|Aside):\s*(.*)', raw_title)
            if cm:
                title = cm.group(1)
            else:
                title = raw_title
            break

    # Determine LaTeX environment
    env = TYPE_TO_ENV.get(seg_type, 'remark')

    out.append(f'\\begin{{{env}}}[{convert_line(title)}]')
    out.append(f'\\label{{{slug}}}')

    i = 0
    first_heading_skipped = False

    while i < len(lines):
        line = lines[i]
        stripped = line.strip()

        # Skip the first heading (already used as environment title)
        if not first_heading_skipped:
            if re.match(r'^#{1,6}\s', line):
                first_heading_skipped = True
                i += 1
                # Also skip the one-sentence summary (next non-empty line)
                while i < len(lines) and lines[i].strip() == '':
                    i += 1
                if i < len(lines) and not re.match(r'^#{1,6}\s', lines[i]) and not lines[i].strip().startswith('*['):
                    # This is the summary line — emit it as the first paragraph
                    out.append(convert_line(lines[i].strip()))
                    out.append('')
                    i += 1
                continue

        # Flush table if we're leaving table context
        if in_table and not stripped.startswith('|'):
            out.append(md_table_to_latex(table_buf))
            out.append('')
            table_buf = []
            in_table = False

        # Flush blockquote
        if in_blockquote and not stripped.startswith('>'):
            out.append(convert_blockquote(blockquote_buf))
            out.append('')
            blockquote_buf = []
            in_blockquote = False

        # Display math blocks
        if stripped == '$$':
            if in_display_math:
                math_content = '\n'.join(display_math_buf)
                out.append(convert_display_math(math_content))
                out.append('')
                display_math_buf = []
                in_display_math = False
            else:
                in_display_math = True
            i += 1
            continue

        if in_display_math:
            display_math_buf.append(line)
            i += 1
            continue

        # Headings → labeled subsections within the segment
        hm = re.match(r'^(#{1,6})\s+(.*)', line)
        if hm:
            heading_text = hm.group(2).strip()
            out.append('')
            out.append(f'\\medskip\\noindent\\textbf{{{convert_line(heading_text)}.}}')
            out.append('')
            i += 1
            continue

        # Lists
        if re.match(r'^[-*]\s', stripped):
            if not in_list:
                in_list = True
                list_type = 'itemize'
                out.append(r'\begin{itemize}')
            item_text = re.sub(r'^[-*]\s+', '', stripped)
            out.append(r'  \item ' + convert_line(item_text))
            i += 1
            continue
        elif re.match(r'^\d+\.\s', stripped):
            if not in_list:
                in_list = True
                list_type = 'enumerate'
                out.append(r'\begin{enumerate}')
            item_text = re.sub(r'^\d+\.\s+', '', stripped)
            out.append(r'  \item ' + convert_line(item_text))
            i += 1
            continue
        else:
            if in_list:
                out.append(f'\\end{{{list_type}}}')
                out.append('')
                in_list = False

        # Tables
        if stripped.startswith('|'):
            in_table = True
            table_buf.append(line)
            i += 1
            continue

        # Blockquotes
        if stripped.startswith('>'):
            in_blockquote = True
            blockquote_buf.append(line)
            i += 1
            continue

        # Equation-level tags: *[Definition (slug-name)]* → marginal note or skip
        tag_m = re.match(r'^\*\[(.+?)\]\*\s*$', stripped)
        if tag_m:
            # In LaTeX, the theorem environment already provides the type label.
            # Emit as a small marginal annotation only for non-redundant tags.
            tag_text = tag_m.group(1)
            # Skip tags that just repeat the segment type
            if not any(tag_text.lower().startswith(t) for t in
                       ('definition', 'postulate', 'formulation')):
                out.append(f'% [{tag_text}]')
            i += 1
            continue

        # Horizontal rules
        if re.match(r'^---+$', stripped) or re.match(r'^\*\*\*+$', stripped):
            out.append(r'\medskip\noindent\rule{\textwidth}{0.4pt}\medskip')
            out.append('')
            i += 1
            continue

        # Empty line → paragraph break
        if stripped == '':
            out.append('')
            i += 1
            continue

        # Regular paragraph text
        out.append(convert_line(stripped))
        i += 1

    # Flush any open environments
    if in_list:
        out.append(f'\\end{{{list_type}}}')
    if in_table:
        out.append(md_table_to_latex(table_buf))
    if in_blockquote:
        out.append(convert_blockquote(blockquote_buf))
    if in_display_math:
        math_content = '\n'.join(display_math_buf)
        out.append(convert_display_math(math_content))

    out.append(f'\\end{{{env}}}')
    out.append('')

    return '\n'.join(out)


def rewrite_crossrefs_md(text, known_slugs):
    """Rewrite cross-references in raw markdown text (before LaTeX conversion).

    Converts #slug-name and [#slug](slug.md) to \\cref{slug} markers that
    survive the LaTeX conversion pipeline (since \\cref is already LaTeX).
    """
    lines = text.split('\n')
    result = []
    in_code = False
    in_display_math = False

    for line in lines:
        stripped = line.strip()

        # Skip code blocks
        if stripped.startswith('```'):
            in_code = not in_code
            result.append(line)
            continue
        if in_code:
            result.append(line)
            continue

        # Skip display math
        if stripped == '$$':
            in_display_math = not in_display_math
            result.append(line)
            continue
        if in_display_math:
            result.append(line)
            continue

        # Replace markdown-style links: [#slug](slug.md) → CREF_MARKER
        def _replace_link_ref(m):
            slug = m.group(1)
            if slug in known_slugs:
                return f'CREF:{slug}:CREF'
            return m.group(0)
        line = re.sub(r'\[#([\w-]+)\]\([^)]*\.md\)', _replace_link_ref, line)

        # Replace standalone #slug-name (not at line start as heading)
        def _replace_ref(m):
            slug = m.group(1)
            if slug in known_slugs:
                return f'CREF:{slug}:CREF'
            return m.group(0)
        if not stripped.startswith('#'):
            line = re.sub(r'(?<!\w)#([a-z][a-z0-9-]*[a-z0-9])(?!\w)', _replace_ref, line)
        else:
            # For heading lines, only replace after the heading markers
            hm = re.match(r'^(#{1,6}\s+)(.*)', line)
            if hm:
                prefix, rest = hm.group(1), hm.group(2)
                rest = re.sub(r'(?<!\w)#([a-z][a-z0-9-]*[a-z0-9])(?!\w)', _replace_ref, rest)
                line = prefix + rest
            else:
                line = re.sub(r'(?<!\w)#([a-z][a-z0-9-]*[a-z0-9])(?!\w)', _replace_ref, line)

        result.append(line)

    return '\n'.join(result)


