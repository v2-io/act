# ── Outline → LaTeX assembly ───────────────────────────────────────────


def parse_outline(index_path):
    """Parse an outline file and return structured data for LaTeX assembly.

    Returns a list of items, each a dict:
      {'kind': 'section', 'level': int, 'title': str, 'scope_text': str}
      {'kind': 'segment', 'slug': str, 'rel_path': str, 'type': str, 'claim': str}
      {'kind': 'gap', 'description': str}
      {'kind': 'text', 'content': str}  (non-table, non-heading lines between sections)
    """
    outline_dir = index_path.parent
    text = index_path.read_text(encoding='utf-8')
    lines = text.split('\n')

    items = []
    in_table = False
    in_frontmatter = False
    frontmatter_dashes = 0

    # Skip YAML frontmatter if present
    start = 0
    if lines and lines[0].strip() == '---':
        for i in range(1, len(lines)):
            if lines[i].strip() == '---':
                start = i + 1
                break

    i = start
    while i < len(lines):
        line = lines[i]
        stripped = line.strip()
        cells = parse_table_row(line)

        # Table start
        if cells and not in_table:
            in_table = True
            i += 1
            continue

        if in_table:
            if cells:
                if is_separator_row(cells):
                    i += 1
                    continue

                is_gap = any('--GAP--' in c for c in cells)
                if is_gap:
                    desc_candidates = [
                        c for c in cells
                        if c and '--GAP--' not in c
                        and not re.match(r'^[IVSA]+$', c.strip())
                    ]
                    gap_desc = desc_candidates[-1] if desc_candidates else 'Open question'
                    items.append({'kind': 'gap', 'description': gap_desc})
                else:
                    slug, rel_path = None, None
                    for c in cells:
                        s, p = extract_slug_and_path(c)
                        if s:
                            slug, rel_path = s, p
                            break
                    type_str = cells[1].strip() if len(cells) > 1 else ''
                    claim_text = cells[4].strip() if len(cells) > 4 else ''
                    if slug:
                        items.append({
                            'kind': 'segment',
                            'slug': slug,
                            'rel_path': rel_path,
                            'type': type_str.lower().split('+')[0].strip(),
                            'claim': claim_text,
                        })

                i += 1
                continue
            else:
                in_table = False
                # fall through to process current line

        # Headings
        hm = re.match(r'^(#{1,6})\s+(.*)', line)
        if hm:
            level = len(hm.group(1))
            heading = hm.group(2).strip()
            items.append({'kind': 'section', 'level': level, 'title': heading})
            i += 1
            continue

        # Scope text (italic blocks between heading and table)
        if stripped.startswith('*') and stripped.endswith('*') and len(stripped) > 2:
            items.append({'kind': 'scope', 'content': stripped})
            i += 1
            continue

        # Horizontal rule
        if re.match(r'^---+$', stripped):
            i += 1
            continue

        # Other text
        if stripped:
            items.append({'kind': 'text', 'content': stripped})

        i += 1

    return items


def build_latex(index_path):
    """Build the complete LaTeX document from an outline file."""
    outline_dir = index_path.parent
    text = index_path.read_text(encoding='utf-8')
    all_lines = text.split('\n')

    known_slugs = collect_slugs(all_lines)
    items = parse_outline(index_path)

    # Extract title from first heading
    doc_title = 'Untitled'
    for item in items:
        if item['kind'] == 'section' and item['level'] == 1:
            doc_title = item['title']
            break

    out = []
    out.append(latex_preamble(doc_title, 'Joseph A.\\ Wecker'))

    stats = {'included': 0, 'missing': 0, 'gaps': 0}

    section_cmds = {
        1: 'section',      # but we already used title for \title
        2: 'section',
        3: 'subsection',
        4: 'subsubsection',
        5: 'paragraph',
        6: 'subparagraph',
    }

    first_heading = True

    for item in items:
        kind = item['kind']

        if kind == 'section':
            if first_heading and item['level'] == 1:
                first_heading = False
                continue  # skip — already in \title
            cmd = section_cmds.get(item['level'], 'paragraph')
            title = convert_line(item['title'])
            out.append(f'\\{cmd}{{{title}}}')
            out.append('')

        elif kind == 'scope':
            # Scope text → italic introductory paragraph
            scope_text = item['content'].strip('*').strip()
            out.append(f'\\begin{{quote}}\\itshape')
            out.append(convert_line(scope_text))
            out.append(f'\\end{{quote}}')
            out.append('')

        elif kind == 'text':
            # Outline preamble text — most of this is development notes
            # Skip lines that reference internal tooling, stages, slugs, etc.
            content = item['content']
            skip_patterns = [
                'Every slug is linked',
                'See [`FORMAT.md`]',
                'See [`NOTATION.md`]',
                '**Working draft.**',
                'Slugs are the stable',
                'Stage column',
            ]
            if any(p in content for p in skip_patterns):
                continue
            out.append(convert_line(content))
            out.append('')

        elif kind == 'gap':
            desc = item['description']
            print(f'  [gap] {desc}', file=sys.stderr)
            stats['gaps'] += 1

        elif kind == 'segment':
            slug = item['slug']
            rel_path = item.get('rel_path')
            seg_type = item['type']

            seg_path = resolve_segment(outline_dir, rel_path, slug) if rel_path else None

            if seg_path and seg_path.exists():
                seg_text = seg_path.read_text(encoding='utf-8')
                latex_content = segment_to_latex(seg_text, slug, seg_type, known_slugs)
                out.append(latex_content)
                stats['included'] += 1
            else:
                print(f'  [missing] {slug}', file=sys.stderr)
                stats['missing'] += 1

    out.append(LATEX_POSTAMBLE)

    return '\n'.join(out), stats


# ── CLI ──────────────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        description='Assemble an outline file into a LaTeX document.'
    )
    parser.add_argument(
        'outline',
        type=Path,
        help='Path to the outline file (e.g., 01-act-core/OUTLINE.md)'
    )
    parser.add_argument(
        '-o', '--output',
        type=Path,
        default=None,
        help='Output file path (default: stdout)'
    )
    parser.add_argument(
        '--author',
        default='Joseph A. Wecker',
        help='Author name for the document'
    )

    args = parser.parse_args()

    index_path = args.outline.resolve()
    if not index_path.exists():
        print(f'Error: {index_path} not found', file=sys.stderr)
        return 1

    text, stats = build_latex(index_path)

    if args.output:
        output_path = args.output.resolve()
        output_path.write_text(text, encoding='utf-8')
        dest = output_path.name
    else:
        sys.stdout.write(text)
        dest = 'stdout'

    total = stats['included'] + stats['missing'] + stats['gaps']
    print(f'\nBuilt → {dest}:', file=sys.stderr)
    print(f'  {stats["included"]} segments included', file=sys.stderr)
    print(f'  {stats["missing"]} segments missing (warned)', file=sys.stderr)
    print(f'  {stats["gaps"]} gaps (warned)', file=sys.stderr)
    print(f'  {total} total entries', file=sys.stderr)

    return 0


if __name__ == '__main__':
    sys.exit(main())
