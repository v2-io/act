#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/extract-recent-progress
#
# Reads CHANGELOG.md and produces doc/readme/src/_recent-progress.md,
# a README-shaped condensed surfacing of the most recent N cycle
# narratives. The full record stays in CHANGELOG.md; this script
# extracts a stable summary that the README pipeline can include.
#
# Usage:
#   bin/extract-recent-progress              # default: 3 most-recent narratives
#   bin/extract-recent-progress --n=5        # surface 5 instead of 3
#   bin/extract-recent-progress --stdout     # write to stdout instead of disk
#
# CHANGELOG structure assumed (see CHANGELOG.md preamble):
#   - H2 (## YYYY-MM-DD) is a date heading, most-recent-first
#   - H3 (### narrative title) is a cycle narrative, most-recent-first
#     within its date
# Cycle narratives are H3 entries; we extract the first N of them
# (which crosses date boundaries naturally if a date has fewer
# narratives than N).
#
# For each narrative, this script emits:
#   - the narrative title (H3 → H4 in the surfaced output, since the
#     including section is itself H2)
#   - the first paragraph of the narrative (the "punchline" that
#     CHANGELOG entries lead with)
#   - a date marker for chronological context
#
# Why the first paragraph: cycle narratives are written most-important-
# first, so the lead paragraph carries the structural news. The full
# narrative is one click away in CHANGELOG.

require 'pathname'
require 'optparse'

REPO_ROOT = Pathname.new(__dir__).parent.expand_path
CHANGELOG = REPO_ROOT.join('CHANGELOG.md')
OUTPUT = REPO_ROOT.join('doc/readme/src/_recent-progress.md')

options = { n: 3, stdout: false }
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/extract-recent-progress [--n=N] [--stdout]'
  opts.on('--n=N', Integer, 'Number of most-recent narratives to surface (default 3)') { |n| options[:n] = n }
  opts.on('--stdout', 'Write to stdout instead of doc/readme/src/_recent-progress.md') { options[:stdout] = true }
end.parse!

raise "CHANGELOG missing: #{CHANGELOG}" unless CHANGELOG.exist?

# Parse CHANGELOG into [date, title, body] tuples for each H3 narrative.
# We track current H2 date as we walk lines so each H3 inherits it.
narratives = []
current_date = nil
current_h3_title = nil
current_h3_lines = []

flush = lambda do
  return unless current_h3_title
  narratives << { date: current_date, title: current_h3_title, body: current_h3_lines.join.strip }
  current_h3_title = nil
  current_h3_lines = []
end

CHANGELOG.each_line do |line|
  if (m = line.match(/\A##\s+(\d{4}-\d{2}-\d{2})\s*\z/))
    flush.call
    current_date = m[1]
  elsif (m = line.match(/\A###\s+(.+?)\s*\z/))
    flush.call
    current_h3_title = m[1]
  elsif current_h3_title
    current_h3_lines << line
  end
end
flush.call

selected = narratives.first(options[:n])

# Extract the first paragraph (up to the first blank line) from each body.
# CHANGELOG narratives lead with a punchline paragraph; subsequent paragraphs
# carry detail that lives in CHANGELOG, not the README surfacing.
def first_paragraph(body)
  paragraphs = body.split(/\n\s*\n/, 2)
  para = paragraphs.first.to_s.strip
  # Trim trailing colon-introducing-list patterns ("Landings (commits A, B, C):"
  # or just trailing ":") so the surfaced lead doesn't read as truncated mid-thought.
  para = para.sub(/\s*\(commits?\s+[^)]+\)\s*:?\s*\z/i, '.')
  para = para.sub(/:\s*\z/, '.')
  para
end

output = +<<~HEADER
  <!-- AUTO-GENERATED by bin/extract-recent-progress; do not hand-edit. -->
  <!-- Surfaces the #{options[:n]} most recent cycle narratives from CHANGELOG.md. -->

  ## Recent Progress

  The #{selected.size} most recent cycle narratives. Full record at [`CHANGELOG.md`](CHANGELOG.md); pre-2026-04-24 archaeology at [`LOG.md`](LOG.md).

HEADER

if selected.empty?
  output << "*(No CHANGELOG narratives found.)*\n"
else
  selected.each do |n|
    output << "### #{n[:title]}\n\n"
    output << "*#{n[:date]}*\n\n" if n[:date]
    output << "#{first_paragraph(n[:body])}\n\n"
  end
end

if options[:stdout]
  print output
else
  OUTPUT.write(output)
  puts "Wrote #{OUTPUT.relative_path_from(REPO_ROOT)} (#{selected.size} narratives, #{output.bytesize} bytes)"
end
